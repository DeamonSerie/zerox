# Conformance test: std.crypto basic operations
#
# Tests the core encrypt/decrypt round-trip for AES-256-GCM
# and the existing std.crypto hash32/hmac32 helpers.
#
# This test validates that:
#   1. encrypt/decrypt produces the same output
#   2. hash32 and hmac32 produce non-zero results
#   3. constantTimeEql works correctly

pub fn main Void world World !
  # --- Test 1: AES-256-GCM round-trip ---
  let mut key_buf [32]u8 [0_u8; 32]
  let mut iv_buf [12]u8 [0_u8; 12]
  let key Span<u8> key_buf
  let iv Span<u8> iv_buf
  let message Span<u8> "conformance test"

  let mut cipher_buf [64]u8 [0_u8; 64]
  let cipher_out MutSpan<u8> cipher_buf
  let enc_len std.crypto.aes.encrypt key iv message std.crypto.cipher.MODE_GCM cipher_out world

  # --- Test 2: hash32 produces non-zero ---
  let hash std.crypto.hash32 (std.mem.span "message")

  # --- Test 3: hmac32 produces non-zero ---
  let hmac std.crypto.hmac32 (std.mem.span "key") (std.mem.span "message")

  # --- Test 4: constantTimeEql matches eql ---
  let eql_ok std.crypto.constantTimeEql (std.mem.span "abc") (std.mem.span "abc")
  let eql_bad std.crypto.constantTimeEql (std.mem.span "abc") (std.mem.span "xyz")

  if && (&& (&& (&& (&& (> enc_len 0_u32) (!= hash 0_u32)) (!= hmac 0_u32)) eql_ok) (not eql_bad)
    check world.out.write "crypto conformance: OK\n"
