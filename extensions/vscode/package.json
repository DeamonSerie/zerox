{
  "name": "zerox-lang",
  "displayName": "Zerox Language",
  "description": "Syntax highlighting for the Zerox programming language.",
  "publisher": "zerox-lang",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "install:cursor": "node scripts/install-cursor-extension.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=24",
    "vscode": "^1.100.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "zerox",
        "aliases": [
          "Zerox",
          "zerox"
        ],
        "extensions": [
          ".0"
        ],
        "configuration": "./language-configuration/zerox.json"
      }
    ],
    "grammars": [
      {
        "language": "zerox",
        "scopeName": "source.zerox",
        "path": "./syntaxes/zerox.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "zerox",
        "path": "./snippets/zerox.json"
      }
    ]
  }
}
