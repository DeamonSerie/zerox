# std.crypto.serpent
#
# Serpent block cipher implementation.
# Designed by Ross Anderson, Eli Biham, and Lars Knudsen.
# AES finalist. Uses 128-bit blocks and 128/192/256-bit keys.
#
# NOTE: Native runtime implementation pending. Returns 0 (error)
# until the C runtime in zero_crypto.c is extended.
#

