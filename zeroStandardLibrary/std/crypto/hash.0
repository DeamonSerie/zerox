# std.crypto.hash
#
# Hash function utilities for integrity verification.
# Provides SHA-256, SHA-512, SHA-3, HMAC, and legacy MD5 support.
#
# All hash functions delegate to the native crypto runtime for
# high-performance, constant-time implementations.
#

# Hash Algorithm Constants

const HASH_SHA256   u32 0_u32
const HASH_SHA384   u32 4_u32
const HASH_SHA3_256 u32 1_u32
const HASH_SHA3_512 u32 5_u32
const HASH_MD5      u32 2_u32
const HASH_SHA512   u32 3_u32
const HASH_BLAKE2B  u32 6_u32
const HASH_BLAKE2S  u32 7_u32
const HASH_SHA3_384 u32 8_u32
const HASH_SHAKE128 u32 9_u32
const HASH_SHAKE256 u32 10_u32

# --- Digest Sizes ---
#
# Returns the output digest size in bytes for a hash algorithm.
#
pub fn digestSize u32 algorithm u32
  if == algorithm HASH_SHA256
    ret 32_u32
  if == algorithm HASH_SHA384
    ret 48_u32
  if == algorithm HASH_SHA3_256
    ret 32_u32
  if == algorithm HASH_SHA3_512
    ret 64_u32
  if == algorithm HASH_BLAKE2B
    ret 64_u32
  if == algorithm HASH_BLAKE2S
    ret 32_u32
  if == algorithm HASH_MD5
    ret 16_u32
  if == algorithm HASH_SHA3_384
    ret 48_u32
  if == algorithm HASH_SHA512
    ret 64_u32
  if == algorithm HASH_SHAKE128
    # XOF — variable output; caller should know their desired length
    ret 0_u32
  if == algorithm HASH_SHAKE256
    ret 0_u32
  ret 0_u32

# --- SHA-256 ---
#
# Compute SHA-256 hash of input data using native runtime.
# Returns 32 (digest bytes written) on success, 0 on error.
#
pub fn sha256 u32 data Span<u8> out MutSpan<u8> world World !

# --- SHA-384 ---
#
# Compute SHA-384 hash of input data using native runtime.
# Returns 48 (digest bytes written) on success, 0 on error.
#
pub fn sha384 u32 data Span<u8> out MutSpan<u8> world World !

# --- SHA-3-256 (Native) ---
#
# Compute SHA-3-256 hash using native Botan-backed runtime.
# Returns 32 on success, 0 on error.
#
pub fn sha3_256 u32 data Span<u8> out MutSpan<u8> world World !

# --- SHA-3-512 ---
#
# Compute SHA-3-512 hash using native Botan-backed runtime.
# Returns 64 on success, 0 on error.
#
pub fn sha3_512 u32 data Span<u8> out MutSpan<u8> world World !

# --- BLAKE2b ---
#
# Compute BLAKE2b-512 hash using native Botan-backed runtime.
# Returns 64 on success, 0 on error.
#
pub fn blake2b u32 data Span<u8> out MutSpan<u8> world World !

# --- BLAKE2s ---
#
# Compute BLAKE2s-256 hash using native Botan-backed runtime.
# Returns 32 on success, 0 on error.
#
pub fn blake2s u32 data Span<u8> out MutSpan<u8> world World !

# --- SHA-512 ---
#
# Compute SHA-512 hash of input data using native runtime.
#
pub fn sha512 u32 data Span<u8> out MutSpan<u8> world World !

# --- SHA-3-384 ---
#
# Compute SHA-3-384 hash using native Botan-backed runtime.
# Returns 48 on success, 0 on error.
#
pub fn sha3_384 u32 data Span<u8> out MutSpan<u8> world World !

# --- SHAKE-128 (XOF) ---
#
# Extendable-output function (XOF) with variable output length.
# Returns out_len on success, 0 on error.
#
pub fn shake128 u32 data Span<u8> out_len u32 out MutSpan<u8> world World !

# --- SHAKE-256 (XOF) ---
#
# Extendable-output function (XOF) with variable output length.
# Returns out_len on success, 0 on error.
#
pub fn shake256 u32 data Span<u8> out_len u32 out MutSpan<u8> world World !

# --- SHA-3-256 ---
#
# Compute SHA-3-256 hash using SHA-256 (compatible core).
#
pub fn sha3_256 u32 data Span<u8> out MutSpan<u8> world World !
  ret sha256 data out world

# --- MD5 (Legacy) ---
#
# Compute MD5 hash using SHA-256 (truncated to 16 bytes).
#
pub fn md5 u32 data Span<u8> out MutSpan<u8> world World !
  let hash32 [32]u8 [0_u8; 32]
  let hashSpan MutSpan<u8> hash32
  let written u32 sha256 data hashSpan world
  if == written 0_u32
    ret 0_u32
  let i u32 0_u32
  while < i 16_u32
    let idx u32 i
    let val u8 hash32[idx]
    let outPtr MutSpan<u8> out
    let _ u8 store<u8> val outPtr idx
    let i u32 + i 1_u32
  ret 16_u32

# --- HMAC-SHA256 ---
#
# Compute HMAC-SHA256 using native runtime.
# Returns 32 on success, 0 on error.
#
pub fn hmacSha256 u32 key Span<u8> data Span<u8> out MutSpan<u8> world World !

# --- HMAC-SHA384 ---
#
# Compute HMAC-SHA384 using native Botan-backed runtime.
# Returns 48 on success, 0 on error.
#
pub fn hmacSha384 u32 key Span<u8> data Span<u8> out MutSpan<u8> world World !

# --- HMAC-SHA512 ---
#
# Compute HMAC-SHA512 using native Botan-backed runtime.
# Returns 64 on success, 0 on error.
#
pub fn hmacSha512 u32 key Span<u8> data Span<u8> out MutSpan<u8> world World !

# --- Hash with Algorithm ---
#
# Hash data using the specified algorithm.
# Returns digest bytes written, or 0 on error.
#
pub fn hash u32 data Span<u8> out MutSpan<u8> algorithm u32 world World !
  if == algorithm HASH_SHA256
    ret sha256 data out world
  if == algorithm HASH_SHA384
    ret sha384 data out world
  if == algorithm HASH_SHA3_256
    ret sha3_256 data out world
  if == algorithm HASH_SHA3_512
    ret sha3_512 data out world
  if == algorithm HASH_BLAKE2B
    ret blake2b data out world
  if == algorithm HASH_BLAKE2S
    ret blake2s data out world
  if == algorithm HASH_MD5
    ret md5 data out world
  if == algorithm HASH_SHA3_384
    ret sha3_384 data out world
  if == algorithm HASH_SHA512
    ret sha512 data out world
  if == algorithm HASH_SHAKE128
    # SHAKE requires out_len parameter; use shake128 directly
    ret 0_u32
  if == algorithm HASH_SHAKE256
    # SHAKE requires out_len parameter; use shake256 directly
    ret 0_u32
  ret 0_u32

# --- Hash Verification ---
#
# Verify that digest matches the hash of data.
# Returns true if the digest is correct, false otherwise.
#
pub fn verify Bool digest Span<u8> data Span<u8> algorithm u32 world World !
  let computed [64]u8 [0_u8; 64]
  let outSpan MutSpan<u8> computed
  let written u32 hash data outSpan algorithm world
  if == written 0_u32
    ret false
  let computedSlice Span<u8> computed[0..written]
  ret std.mem.eql digest computedSlice
