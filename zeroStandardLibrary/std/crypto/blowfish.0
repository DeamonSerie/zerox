# std.crypto.blowfish
#
# Blowfish block cipher implementation.
# Designed by Bruce Schneier in 1993.
#
# Key sizes: 4 to 56 bytes (32 to 448 bits)
# Block size: 8 bytes (64 bits)
#
# NOTE: Native runtime implementation pending. Returns 0 (error)
# until the C runtime in zero_crypto.c is extended.
#

# --- Blowfish Encrypt ---

pub fn encrypt u32 key Span<u8> iv Span<u8> data Span<u8> mode u32 out MutSpan<u8> world World !
  ret 0_u32

# --- Blowfish Decrypt ---

pub fn decrypt u32 key Span<u8> iv Span<u8> data Span<u8> mode u32 out MutSpan<u8> world World !
  ret 0_u32
