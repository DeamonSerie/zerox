# std.math.vector
#
# 2D and 3D vector mathematics: dot products, cross products,
# normalization, reflection, and linear interpolation.
#
# All vectors use f64 components.

# --- 2D Vector ---

# A 2D vector with x and y components.
#
pub type Vec2
  x f64
  y f64

# Create a 2D vector.
#
pub fn vec2 Vec2 x f64 y f64
  ret Vec2 . x x y y

# Create a zero 2D vector.
#
pub fn vec2Zero Vec2
  ret Vec2 . x 0.0 y 0.0

# Add two 2D vectors.
#
pub fn add2 Vec2 a Vec2 b Vec2
  ret Vec2 . x (+ a.x b.x) y (+ a.y b.y)

# Subtract two 2D vectors.
#
pub fn sub2 Vec2 a Vec2 b Vec2
  ret Vec2 . x (- a.x b.x) y (- a.y b.y)

# Scale a 2D vector by a scalar.
#
pub fn scale2 Vec2 a Vec2 s f64
  ret Vec2 . x (* a.x s) y (* a.y s)

# Compute the dot product of two 2D vectors.
#
pub fn dot2 f64 a Vec2 b Vec2
  ret + (* a.x b.x) (* a.y b.y)

# Compute the length (magnitude) of a 2D vector.
#
pub fn length2 f64 a Vec2
  ret sqrt (+ (* a.x a.x) (* a.y a.y))

# Compute the squared length of a 2D vector (avoids sqrt).
#
pub fn lengthSq2 f64 a Vec2
  ret + (* a.x a.x) (* a.y a.y)

# Normalize a 2D vector to unit length.
# Returns zero vector if input length is zero.
#
pub fn normalize2 Vec2 a Vec2
  let lenSq f64 lengthSq2 a
  if isZero lenSq
    ret Vec2 . x 0.0 y 0.0
  let len f64 sqrt lenSq
  ret Vec2 . x (/ a.x len) y (/ a.y len)

# Compute the distance between two 2D points.
#
pub fn distance2 f64 a Vec2 b Vec2
  ret length2 (sub2 a b)

# Reflect a 2D vector about a surface normal.
# r = v - 2*(v·n)*n
#
pub fn reflect2 Vec2 v Vec2 n Vec2
  let d f64 dot2 v n
  ret sub2 v (scale2 n (* 2.0 d))

# Linearly interpolate between two 2D vectors.
#
pub fn lerp2 Vec2 a Vec2 b Vec2 t f64
  ret Vec2 . x (lerp a.x b.x t) y (lerp a.y b.y t)

# --- 3D Vector ---

# A 3D vector with x, y, and z components.
#
pub type Vec3
  x f64
  y f64
  z f64

# Create a 3D vector.
#
pub fn vec3 Vec3 x f64 y f64 z f64
  ret Vec3 . x x y y z z

# Create a zero 3D vector.
#
pub fn vec3Zero Vec3
  ret Vec3 . x 0.0 y 0.0 z 0.0

# Add two 3D vectors.
#
pub fn add3 Vec3 a Vec3 b Vec3
  ret Vec3 . x (+ a.x b.x) y (+ a.y b.y) z (+ a.z b.z)

# Subtract two 3D vectors.
#
pub fn sub3 Vec3 a Vec3 b Vec3
  ret Vec3 . x (- a.x b.x) y (- a.y b.y) z (- a.z b.z)

# Scale a 3D vector by a scalar.
#
pub fn scale3 Vec3 a Vec3 s f64
  ret Vec3 . x (* a.x s) y (* a.y s) z (* a.z s)

# Compute the dot product of two 3D vectors.
#
pub fn dot3 f64 a Vec3 b Vec3
  ret + (+ (* a.x b.x) (* a.y b.y)) (* a.z b.z)

# Compute the cross product of two 3D vectors.
# a x b = (a.y*b.z - a.z*b.y, a.z*b.x - a.x*b.z, a.x*b.y - a.y*b.x)
#
pub fn cross3 Vec3 a Vec3 b Vec3
  ret Vec3 . x (- (* a.y b.z) (* a.z b.y)) y (- (* a.z b.x) (* a.x b.z)) z (- (* a.x b.y) (* a.y b.x))

# Compute the length (magnitude) of a 3D vector.
#
pub fn length3 f64 a Vec3
  ret sqrt (+ (+ (* a.x a.x) (* a.y a.y)) (* a.z a.z))

# Compute the squared length of a 3D vector (avoids sqrt).
#
pub fn lengthSq3 f64 a Vec3
  ret + (+ (* a.x a.x) (* a.y a.y)) (* a.z a.z)

# Normalize a 3D vector to unit length.
# Returns zero vector if input length is zero.
#
pub fn normalize3 Vec3 a Vec3
  let lenSq f64 lengthSq3 a
  if isZero lenSq
    ret Vec3 . x 0.0 y 0.0 z 0.0
  let len f64 sqrt lenSq
  ret Vec3 . x (/ a.x len) y (/ a.y len) z (/ a.z len)

# Compute the distance between two 3D points.
#
pub fn distance3 f64 a Vec3 b Vec3
  ret length3 (sub3 a b)

# Reflect a 3D vector about a surface normal.
# r = v - 2*(v·n)*n
#
pub fn reflect3 Vec3 v Vec3 n Vec3
  let d f64 dot3 v n
  ret sub3 v (scale3 n (* 2.0 d))

# Refract a 3D vector through a surface.
# Uses Snell's law: t = eta * v - (eta * dot(v, n) + sqrt(1 - eta^2 * (1 - dot(v, n)^2))) * n
#
pub fn refract3 Vec3 v Vec3 n Vec3 eta f64
  let d f64 dot3 v n
  let k f64 - 1.0 (* eta eta (- 1.0 (* d d)))
  if < k 0.0
    ret vec3Zero
  let sqrtK f64 sqrt k
  let s f64 - (* eta d) sqrtK
  ret sub3 (scale3 v eta) (scale3 n s)

# Linearly interpolate between two 3D vectors.
#
pub fn lerp3 Vec3 a Vec3 b Vec3 t f64
  ret Vec3 . x (lerp a.x b.x t) y (lerp a.y b.y t) z (lerp a.z b.z t)

# Test vector functions
test "vec2 operations work"
  let a Vec2 vec2 3.0 4.0
  let b Vec2 vec2 1.0 2.0
  let sum Vec2 add2 a b
  expect (approxEq sum.x 4.0 DEFAULT_TOLERANCE)
  expect (approxEq sum.y 6.0 DEFAULT_TOLERANCE)
  let dot f64 dot2 a b
  expect (approxEq dot 11.0 DEFAULT_TOLERANCE)
  let len f64 length2 a
  expect (approxEq len 5.0 DEFAULT_TOLERANCE)
  let n Vec2 normalize2 a
  expect (approxEq (length2 n) 1.0 1.0e-6)

test "vec3 operations work"
  let a Vec3 vec3 1.0 0.0 0.0
  let b Vec3 vec3 0.0 1.0 0.0
  let cross Vec3 cross3 a b
  expect (approxEq cross.x 0.0 DEFAULT_TOLERANCE)
  expect (approxEq cross.y 0.0 DEFAULT_TOLERANCE)
  expect (approxEq cross.z 1.0 DEFAULT_TOLERANCE)
  let dot f64 dot3 a b
  expect (approxEq dot 0.0 DEFAULT_TOLERANCE)
  let n Vec3 normalize3 a
  expect (approxEq (length3 n) 1.0 DEFAULT_TOLERANCE)

test "reflect and refract work"
  let v Vec3 vec3 1.0 (- 0.0 1.0) 0.0
  let n Vec3 vec3 0.0 1.0 0.0
  let r Vec3 reflect3 v n
  expect (approxEq r.x 1.0 DEFAULT_TOLERANCE)
  expect (approxEq r.y 1.0 DEFAULT_TOLERANCE)

test "distance works"
  let a Vec2 vec2 0.0 0.0
  let b Vec2 vec2 3.0 4.0
  expect (approxEq (distance2 a b) 5.0 DEFAULT_TOLERANCE)
  let a3 Vec3 vec3 0.0 0.0 0.0
  let b3 Vec3 vec3 1.0 2.0 2.0
  expect (approxEq (distance3 a3 b3) 3.0 DEFAULT_TOLERANCE)
